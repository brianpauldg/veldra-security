# ============================================================
# Nova Health — Production Environment Variables (Vercel)
# Copy these env var names into Vercel dashboard
# Settings → Environment Variables → Add each one
# ============================================================

# ── PUBLIC VARIABLES (safe to expose, visible in client) ────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# ── SECRET VARIABLES (server-only, never expose) ────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_XXXXXXXXXXXXXX
STRIPE_TRIAL_DAYS=14

ENCRYPTION_KEY=64-hex-char-string-generated-locally
ANTHROPIC_API_KEY=sk-ant-your-key-here
REGOLOGY_API_KEY=your-regology-key-here
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=notifications@novahealth.io

CSRF_SECRET=64-hex-char-string-generated-locally

# Optional for rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
